/* まるみのある学習向けフォント(このリポジトリ内に同梱・オフラインでも表示可) */
@font-face {
  font-family: "Zen Maru Gothic";
  src: url("../fonts/zen-maru-regular.woff2") format("woff2");
  font-weight: 400; font-display: swap;
}
@font-face {
  font-family: "Zen Maru Gothic";
  src: url("../fonts/zen-maru-bold.woff2") format("woff2");
  font-weight: 700; font-display: swap;
}

:root {
  --ink: #183b36;
  --muted: #58706b;
  --green: #176b52;
  --green-dark: #0e4f3c;
  --mint: #dff5e8;
  --sky: #dff5ff;
  --cream: #fff9df;
  --corn: #ffd95c;
  --coral: #ef6a5b;
  --white: #fff;
  --shadow: 0 10px 0 rgba(19, 78, 61, .12);
  --focus: #7b2cbf;
}

* { box-sizing: border-box; }
html { min-width: 320px; color-scheme: light; }
body {
  margin: 0;
  color: var(--ink);
  background:
    linear-gradient(150deg, transparent 0 52%, rgba(23, 107, 82, .05) 52% 56%, transparent 56%),
    linear-gradient(var(--sky) 0 30%, var(--cream) 30% 100%);
  font-family: "Zen Maru Gothic", "Hiragino Maru Gothic ProN", "BIZ UDPGothic", "Yu Gothic", system-ui, sans-serif;
  min-height: 100vh;
}
button, a { font: inherit; }
button { color: inherit; }
button:not(:disabled), a { cursor: pointer; }
button:focus-visible, a:focus-visible, summary:focus-visible {
  outline: 4px solid var(--focus);
  outline-offset: 3px;
}
.skip-link {
  position: fixed;
  z-index: 20;
  top: 8px;
  left: 8px;
  padding: 10px 16px;
  color: #fff;
  background: var(--focus);
  border-radius: 10px;
  transform: translateY(-160%);
}
.skip-link:focus { transform: none; }
[hidden] { display: none !important; }

.site-header {
  width: min(1120px, calc(100% - 32px));
  min-height: 64px;
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 5px;
  border: 0;
  background: transparent;
  color: var(--green-dark);
  font-size: 1.12rem;
  font-weight: 900;
  text-align: left;
}
.brand img {
  width: 46px;
  height: 46px;
  object-fit: cover;
  border: 3px solid var(--corn);
  background: #fff;
  border-radius: 50%;
}
.brand small { display: block; color: var(--ink); font-size: .68rem; font-weight: 700; }
.icon-button {
  min-width: 108px;
  min-height: 44px;
  padding: 8px 12px;
  border: 2px solid var(--green);
  border-radius: 999px;
  background: #fff;
  font-weight: 900;
}
.sound-label { margin-left: 5px; font-size: .8rem; }

.app-shell { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }
.screen { animation: screen-in .25s ease-out; }
.loading-message {
  margin: 15vh auto;
  width: max-content;
  max-width: 100%;
  padding: 16px 22px;
  background: #fff;
  border-radius: 16px;
  box-shadow: var(--shadow);
  font-weight: 900;
}
.hero-card {
  min-height: 205px;
  display: grid;
  grid-template-columns: 1fr 210px;
  align-items: center;
  padding: clamp(18px, 3vw, 34px);
  overflow: hidden;
  color: #fff;
  background:
    radial-gradient(circle at 75% 15%, rgba(255,255,255,.22) 0 5px, transparent 6px),
    linear-gradient(120deg, var(--green-dark), var(--green));
  border: 4px solid #fff;
  border-radius: 30px;
  box-shadow: var(--shadow);
}
.hero-copy { position: relative; z-index: 1; }
.eyebrow {
  margin: 0 0 5px;
  color: inherit;
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .08em;
}
.hero-card h1 { margin: 0; font-size: clamp(2.5rem, 7vw, 4.7rem); line-height: .95; }
.hero-card h1 span { display: block; color: var(--corn); font-size: .63em; }
.hero-card p:not(.eyebrow) { margin: 12px 0; font-weight: 700; }
.hero-mascot {
  width: 250px;
  max-width: 120%;
  margin: -22px -20px -55px auto;
  filter: drop-shadow(0 8px 0 rgba(0,0,0,.13));
}
.record-row { display: flex; flex-wrap: wrap; gap: 8px; }
.record-row span {
  padding: 7px 12px;
  color: var(--ink);
  background: #fff;
  border-radius: 999px;
  font-size: .85rem;
}
.resume-card {
  margin-top: 14px;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: #fff;
  border: 2px solid var(--corn);
  border-radius: 16px;
}
.resume-card span { display: block; color: var(--muted); font-size: .82rem; }
.small-button, .primary-button, .secondary-button, .text-button, .read-button {
  min-height: 44px;
  border-radius: 13px;
  font-weight: 900;
}
.small-button { padding: 7px 16px; color: #fff; background: var(--green); border: 0; white-space: nowrap; }
.section-heading {
  margin: 22px 3px 11px;
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 12px;
}
.section-heading h2 { margin: 0; font-size: clamp(1.25rem, 3vw, 1.65rem); }
.section-heading > p { margin: 0; color: var(--muted); font-size: .83rem; font-weight: 700; }
.course-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.course-card {
  position: relative;
  min-width: 0;
  min-height: 168px;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: end;
  gap: 8px;
  padding: 20px;
  overflow: hidden;
  text-align: left;
  border: 3px solid #fff;
  border-radius: 24px;
  box-shadow: 0 7px 0 rgba(25, 70, 58, .15);
}
.course-card[data-course="beginner"] { background: #c9efa1; }
.course-card[data-course="intermediate"] { background: #b8e8f5; }
.course-card[data-course="advanced"] { background: #ffe582; }
.course-card .course-icon { position: absolute; right: 12px; top: 8px; font-size: 3.1rem; opacity: .9; }
.course-card .course-number { font-size: .75rem; font-weight: 900; }
.course-card strong { display: block; max-width: 80%; margin: 8px 0 4px; font-size: 1.2rem; line-height: 1.25; }
.course-card small { color: var(--muted); font-weight: 700; }
.course-card .course-play {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  color: #fff;
  background: var(--green-dark);
  border-radius: 50%;
}
.course-card:hover { transform: translateY(-3px); }
.teacher-panel { margin: 20px 0; padding: 18px; background: #fff; border: 3px dashed var(--green); border-radius: 18px; }
.teacher-panel h2 { margin-top: 0; }
.teacher-panel li { margin-block: 6px; }

.quiz-toolbar {
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.text-button { padding: 8px 12px; border: 0; color: var(--green-dark); background: transparent; }
.progress-copy { display: flex; gap: 9px; font-weight: 900; }
.progress-copy span { padding: 6px 11px; background: rgba(255,255,255,.88); border-radius: 999px; }
.progress-track {
  height: 11px;
  margin: 8px 0 12px;
  overflow: hidden;
  background: rgba(255,255,255,.78);
  border: 2px solid #fff;
  border-radius: 999px;
}
.progress-track span { display: block; width: 20%; height: 100%; background: linear-gradient(90deg, var(--green), #89c95f); transition: width .25s ease; }
.question-card {
  min-height: 490px;
  padding: clamp(18px, 3vw, 30px);
  background: rgba(255,255,255,.96);
  border: 4px solid #fff;
  border-radius: 28px;
  box-shadow: var(--shadow);
}
.question-heading { display: flex; align-items: start; justify-content: space-between; gap: 16px; }
.course-label {
  display: inline-block;
  margin: 0 0 8px;
  padding: 5px 11px;
  color: var(--green-dark);
  background: var(--mint);
  border-radius: 999px;
  font-size: .8rem;
  font-weight: 900;
}
.question-card h1 { margin: 0; max-width: 850px; font-size: clamp(1.5rem, 3.7vw, 2.35rem); line-height: 1.45; }
.read-button { flex: 0 0 auto; padding: 8px 13px; color: var(--green-dark); background: #fff; border: 2px solid var(--green); }
.choice-list { margin-top: 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.choice-button {
  position: relative;
  min-height: 92px;
  padding: 16px 12px 16px 53px;
  text-align: left;
  background: #f8fbf9;
  border: 3px solid #bfd8cf;
  border-radius: 18px;
  font-size: clamp(.95rem, 1.7vw, 1.14rem);
  font-weight: 900;
  line-height: 1.45;
}
.choice-number {
  position: absolute;
  left: 12px;
  top: 50%;
  width: 30px;
  height: 30px;
  display: grid;
  place-items: center;
  transform: translateY(-50%);
  color: #fff;
  background: var(--green);
  border-radius: 50%;
}
.choice-button:hover:not(:disabled) { border-color: var(--green); background: var(--mint); transform: translateY(-2px); }
.choice-button.correct { color: #0b513b; border-color: #178b62; background: #dff8e8; }
.choice-button.correct::after { content: "○ せいかい"; position: absolute; right: 7px; bottom: 5px; font-size: .72rem; }
.choice-button.wrong { color: #7c2721; border-color: var(--coral); background: #fff0ed; }
.choice-button.wrong::after { content: "△ おしい"; position: absolute; right: 7px; bottom: 5px; font-size: .72rem; }
.feedback {
  margin-top: 18px;
  display: grid;
  grid-template-columns: 74px 1fr auto;
  align-items: center;
  gap: 15px;
  padding: 14px 16px;
  background: var(--cream);
  border: 3px solid var(--corn);
  border-radius: 20px;
}
.feedback img { width: 72px; height: 72px; object-fit: contain; }
.feedback h2 { margin: 0 0 3px; font-size: 1.25rem; }
.feedback p { margin: 3px 0; }
.feedback-answer { color: var(--green-dark); font-weight: 900; }
.feedback details { color: var(--muted); font-size: .8rem; }
.primary-button { padding: 10px 18px; color: #fff; background: var(--green); border: 2px solid var(--green); box-shadow: 0 4px 0 var(--green-dark); }
.secondary-button { padding: 10px 18px; color: var(--green-dark); background: #fff; border: 2px solid var(--green); }
.keyboard-help { margin: 8px; color: var(--muted); text-align: center; font-size: .75rem; }

.result-card {
  width: min(700px, 100%);
  margin: 30px auto;
  padding: clamp(24px, 5vw, 42px);
  text-align: center;
  background: rgba(255,255,255,.97);
  border: 5px solid var(--corn);
  border-radius: 30px;
  box-shadow: var(--shadow);
}
.result-mascot { width: 120px; height: 100px; object-fit: contain; margin-top: -15px; }
.result-card h1 { margin: 4px 0; font-size: clamp(2rem, 6vw, 3.2rem); }
.score-display { display: flex; align-items: baseline; justify-content: center; gap: 6px; }
.score-display strong { color: var(--green); font-size: 4.5rem; line-height: 1; }
.score-display span { font-size: 1.5rem; font-weight: 900; }
.star-row { margin: 5px 0; font-size: clamp(1.4rem, 5vw, 2.2rem); letter-spacing: .15em; }
.discovery-list { margin: 14px 0; display: flex; justify-content: center; flex-wrap: wrap; gap: 6px; }
.discovery-list span { padding: 6px 10px; background: var(--mint); border-radius: 999px; font-size: .8rem; font-weight: 900; }
.result-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
.error-card { margin: 10vh auto; max-width: 620px; padding: 30px; text-align: center; background: #fff; border-radius: 24px; }

footer {
  width: min(1120px, calc(100% - 32px));
  min-height: 58px;
  margin: 20px auto 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  color: var(--muted);
  font-size: .72rem;
}
footer a { color: var(--green-dark); }

@media (max-width: 820px) {
  .course-grid { grid-template-columns: 1fr; }
  .course-card { min-height: 115px; }
  .choice-list { grid-template-columns: 1fr; gap: 9px; margin-top: 16px; }
  .choice-button { min-height: 68px; }
  .question-card { min-height: 0; }
  .feedback { grid-template-columns: 55px 1fr; }
  .feedback img { width: 52px; height: 52px; }
  .feedback .primary-button { grid-column: 1 / -1; }
}
@media (max-width: 560px) {
  .site-header, .app-shell, footer { width: min(100% - 20px, 1120px); }
  .brand { font-size: .92rem; }
  .brand img { width: 40px; height: 40px; }
  .icon-button { min-width: 48px; }
  .sound-label { display: none; }
  .hero-card { min-height: 188px; grid-template-columns: 1fr 105px; border-radius: 22px; }
  .hero-card h1 { font-size: 2.65rem; }
  .hero-copy > p:not(.eyebrow) { max-width: 230px; }
  .hero-mascot { width: 155px; margin: 0 -34px -70px -15px; }
  .section-heading > p, .keyboard-help { display: none; }
  .question-card { padding: 16px; border-radius: 21px; }
  .question-heading { display: block; }
  .read-button { margin-top: 10px; }
  .result-card { margin-top: 10px; }
}
@media (max-height: 700px) and (min-width: 821px) {
  .site-header { min-height: 54px; }
  .brand img { width: 40px; height: 40px; }
  .hero-card { min-height: 175px; }
  .course-card { min-height: 145px; }
  .section-heading { margin-top: 14px; }
  .question-card { min-height: 430px; }
  .choice-button { min-height: 80px; }
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { scroll-behavior: auto !important; animation: none !important; transition: none !important; }
}
@media print {
  .site-header, footer, .hero-card, .resume-card { display: none; }
  body { background: #fff; }
  .app-shell { width: 100%; }
  .course-card, .question-card, .result-card { box-shadow: none; }
}
@keyframes screen-in {
  from { opacity: 0; transform: translateY(5px); }
  to { opacity: 1; transform: none; }
}

/* ふりがな(ルビ)の見た目 */
ruby { ruby-align: center; white-space: nowrap; }
rt { font-size: .5em; font-weight: 700; color: #2f5d43; }
